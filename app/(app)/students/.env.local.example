# انسخ هذا الملف إلى .env.local واملأ القيم من لوحة Supabase
# (Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# ملاحظة أمنية: المفتاح العام (anon/publishable) آمن للعرض في المتصفح،
# لأن سياسات RLS هي ما يحمي البيانات فعلياً — لا المفتاح.
# لا تضع service_role key هنا أبداً (سرّي، للخادم فقط).
