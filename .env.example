# ============================================================================
# RusoomPay — متغيّرات البيئة (انسخ هذا الملف إلى .env.local واملأ القيم)
# ============================================================================

# --- Supabase (أساسي) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# مفتاح الخدمة — سرّي جداً، للخادم/العامل فقط، لا يُرسل للمتصفّح أبداً
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- حماية مهام الـCron (سرّ عشوائي قوي) ---
CRON_SECRET=generate-a-long-random-string

# --- مزوّد البريد (Resend مثلاً) — اختياري حتى تفعّل الإشعارات ---
EMAIL_API_KEY=
EMAIL_FROM=RusoomPay <noreply@yourdomain.com>

# --- مزوّد SMS (Twilio مثلاً) — اختياري ---
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# --- WhatsApp Cloud API — اختياري ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# --- Push (FCM) — اختياري ---
FCM_SERVER_KEY=

# ملاحظة: الإشعارات غير المُهيّأة تُسجَّل في الطابور كـ"فشل: غير مُهيّأ"
# بصدق بدل التظاهر بالإرسال — فعّل المزوّد الذي تحتاجه فقط.
